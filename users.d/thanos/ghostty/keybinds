keybind = global:super+§=toggle_quick_terminal
keybind = cmd+backspace=text:\15

keybind = alt+enter=toggle_split_zoom
keybind = shift+alt+up=new_split:up
keybind = shift+alt+down=new_split:down
keybind = shift+alt+left=new_split:left
keybind = shift+alt+right=new_split:right

keybind = shift+super+up=goto_split:top
keybind = shift+super+down=goto_split:bottom
keybind = shift+super+left=goto_split:left
keybind = shift+super+right=goto_split:right

keybind = shift+enter=text:\x1b\r